{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "eternlwallet.com" }],
      "destination": "https://www.eternlwallet.com/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/((?!_next/static|_next/image|favicon.ico|brand|fonts|.*\\..*).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, no-cache, no-store, max-age=0, must-revalidate"
        },
        {
          "key": "CDN-Cache-Control",
          "value": "no-store"
        },
        {
          "key": "Vercel-CDN-Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
